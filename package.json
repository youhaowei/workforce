{
  "name": "workforce",
  "version": "0.1.0",
  "description": "High-performance desktop agentic orchestrator with Claude Code parity",
  "type": "module",
  "main": ".vite/build/main.cjs",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "setup": "git submodule update --init --recursive && pnpm install",
    "dev": "bash scripts/dev-electron.sh",
    "dev:web": "bash scripts/dev-preview.sh",
    "routes:generate": "tsr generate",
    "server": "tsx src/server/index.ts",
    "server:watch": "PORT=${PORT:-19675} tsx --watch src/server/index.ts",
    "build": "pnpm run vite:build && electron-forge make",
    "package": "pnpm run vite:build && electron-forge package",
    "release": "pnpm run build",
    "clean": "rm -rf dist out .vite",
    "vite": "vite",
    "vite:build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "lint": "eslint src src-electron tooling --max-warnings 0",
    "type-check": "tsc --noEmit",
    "cli": "tsx src/cli/index.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.50",
    "@hono/node-server": "^1",
    "@hono/trpc-server": "^0.4.2",
    "@radix-ui/react-popover": "^1.1.15",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-query": "^5",
    "@tanstack/react-router": "^1.166.2",
    "@trpc/client": "^11",
    "@trpc/server": "^11",
    "@trpc/tanstack-react-query": "^11",
    "@vitejs/plugin-react": "^5.1.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "commander": "^14.0.3",
    "dompurify": "^3.3.1",
    "hono": "^4.11.7",
    "immer": "^11.1.3",
    "jotai": "^2",
    "lucide-react": "^0.563.0",
    "marked": "^17.0.1",
    "motion": "^12.34.4",
    "radix-ui": "^1.4.3",
    "react": "^19",
    "react-dom": "^19",
    "react-hotkeys-hook": "^5.2.4",
    "react-virtuoso": "^4.18.1",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.4.0",
    "pino": "^9.6.0",
    "zod": "^3.22.0",
    "zustand": "^5"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7",
    "@electron-forge/maker-dmg": "^7",
    "@electron-forge/maker-zip": "^7",
    "@electron-forge/plugin-vite": "^7",
    "@playwright/test": "^1.58.1",
    "@tanstack/router-cli": "^1.166.2",
    "@tanstack/router-plugin": "^1.166.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "electron": "^36",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "jsdom": "^27.4.0",
    "pino-pretty": "^13.0.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.1.18",
    "tsx": "^4",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "pnpm": {
    "overrides": {
      "@openai/codex": "0.107.0"
    },
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "fs-xattr",
      "macos-alias"
    ]
  },
  "engines": {
    "node": ">=20"
  }
}
