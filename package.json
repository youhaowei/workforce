{
  "name": "workforce",
  "version": "0.1.0",
  "description": "High-performance desktop agentic orchestrator with Claude Code parity",
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "dev:web": "bash scripts/dev-preview.sh",
    "server": "bun --tsconfig-override tsconfig.json src/server/index.ts",
    "server:watch": "PORT=${PORT:-19675} bun --tsconfig-override tsconfig.json --watch src/server/index.ts",
    "build": "tauri build",
    "release": "tauri build",
    "clean": "rm -rf dist src-tauri/target",
    "vite": "vite",
    "vite:build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:event-bus": "vitest run src/shared/event-bus.test.ts",
    "lint": "eslint src --max-warnings 0",
    "type-check": "tsc --noEmit",
    "cli": "bun run src/cli/index.ts",
    "tauri": "tauri"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.50",
    "@hono/trpc-server": "^0.4.2",
    "@radix-ui/react-popover": "^1.1.15",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-query": "^5",
    "@tanstack/react-router": "^1.166.2",
    "@tauri-apps/api": "^2",
    "@trpc/client": "^11",
    "@trpc/server": "^11",
    "@trpc/tanstack-react-query": "^11",
    "@vitejs/plugin-react": "^5.1.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "commander": "^14.0.3",
    "dompurify": "^3.3.1",
    "hono": "^4.11.7",
    "immer": "^11.1.3",
    "jotai": "^2",
    "lucide-react": "^0.563.0",
    "marked": "^17.0.1",
    "motion": "^12.34.4",
    "radix-ui": "^1.4.3",
    "react": "^19",
    "react-dom": "^19",
    "react-hotkeys-hook": "^5.2.4",
    "react-virtuoso": "^4.18.1",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.4.0",
    "pino": "^9.6.0",
    "zod": "^3.22.0",
    "zustand": "^5"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.1",
    "@tanstack/router-plugin": "^1.166.2",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16",
    "@types/bun": "^1",
    "@types/dompurify": "^3.2.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "jsdom": "^27.4.0",
    "pino-pretty": "^13.0.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
