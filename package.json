{
  "name": "workforce",
  "version": "0.1.0",
  "description": "High-performance desktop agentic orchestrator with Claude Code parity",
  "type": "module",
  "scripts": {
    "dev": "lsof -ti:4096 | xargs kill -9 2>/dev/null; bun run server:watch & sleep 2 && tauri dev",
    "dev:web": "bun run server:watch & bun run vite",
    "server": "bun run src/server/index.ts",
    "server:watch": "bun --watch run src/server/index.ts",
    "build:server": "bun run scripts/build-server-sidecar.ts",
    "build:server:all": "bun run scripts/build-server-sidecar.ts --all",
    "build:all": "bun run build:server:all",
    "build": "tauri build -c src-tauri/tauri.bundle.conf.json",
    "clean": "rm -rf src-tauri/target src-tauri/binaries dist dist-server",
    "vite": "vite",
    "vite:build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:event-bus": "vitest run src/shared/event-bus.test.ts",
    "bench:event-bus": "bun scripts/bench-event-bus.js",
    "perf:startup": "node scripts/perf-startup.js",
    "perf:memory": "node scripts/perf-memory.js",
    "perf:stream": "node scripts/perf-stream.js",
    "lint": "eslint src --max-warnings 0",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.29",
    "unifai": "file:../unifai",
    "@hono/trpc-server": "^0.4.2",
    "@radix-ui/react-popover": "^1.1.15",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-query": "^5",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@trpc/client": "^11",
    "@trpc/server": "^11",
    "@trpc/tanstack-react-query": "^11",
    "@vitejs/plugin-react": "^5.1.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dompurify": "^3.3.1",
    "hono": "^4.11.7",
    "immer": "^11.1.3",
    "jotai": "^2",
    "lucide-react": "^0.563.0",
    "marked": "^17.0.1",
    "radix-ui": "^1.4.3",
    "react": "^19",
    "react-dom": "^19",
    "react-hotkeys-hook": "^5.2.4",
    "react-virtuoso": "^4.18.1",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.4.0",
    "zod": "^3.22.0",
    "zustand": "^5"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.1",
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16",
    "@types/bun": "^1.3.9",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^25.1.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "jsdom": "^27.4.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
