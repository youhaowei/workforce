{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Workforce",
  "version": "0.1.0",
  "identifier": "com.workforce.app",
  "build": {
    "beforeDevCommand": "PORT=19675 VITE_PORT=19676 bun run dev:web",
    "beforeBuildCommand": "bun run vite:build",
    "devUrl": "http://localhost:19676",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Workforce",
        "width": 1200,
        "height": 800,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "decorations": true,
        "dragDropEnabled": true,
        "acceptFirstMouse": true,
        "trafficLightPosition": { "x": 8, "y": 22 }
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:* ws://localhost:*; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; script-src 'self'"
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "externalBin": ["binaries/bun"]
  }
}
