{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "tracey": ["lib/tracey/src/index.ts"],
      "tracey/*": ["lib/tracey/src/*"],
      "unifai": ["lib/unifai/src/index.ts"],
      "@wystack/types": ["lib/wystack/packages/types/src/index.ts"],
      "@wystack/version": ["lib/wystack/packages/version/src/index.ts"],
      "@wystack/db": ["lib/wystack/packages/db/src/index.ts"],
      "@wystack/server": ["lib/wystack/packages/server/src/index.ts"],
      "@wystack/client": ["lib/wystack/packages/client/src/index.ts"],
      "@wystack/start": ["lib/wystack/packages/start/src/index.ts"],
      "@stdui/react": ["lib/stdui/packages/ui/src/index.ts"],
      "@stdui/react/*": ["lib/stdui/packages/ui/src/*"]
    },
    "types": ["vitest/globals", "vite/client", "bun"]
  },
  "include": ["src", "lib/tracey/src", "lib/unifai/src", "lib/wystack/packages/types/src", "lib/wystack/packages/version/src"],
  "exclude": ["node_modules", "dist", "dist-electron", "build", "src-tauri", "src-electron", "lib/wystack/packages/*/src/__tests__"]
}
