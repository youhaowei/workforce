{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "tracey": ["lib/tracey/src/index.ts"],
      "tracey/*": ["lib/tracey/src/*"],
      "unifai": ["lib/unifai/src/index.ts"]
    },
    "types": ["vitest/globals", "vite/client", "bun"]
  },
  "include": ["src", "lib/tracey/src", "lib/unifai/src"],
  "exclude": ["node_modules", "dist", "build", "src-tauri"]
}
